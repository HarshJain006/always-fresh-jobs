# Copy to .env (local) / Netlify env / Raspberry Pi env

VITE_APP_URL=https://dailyresume.in

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# REQUIRED on Netlify + Raspberry Pi (never VITE_ / never commit)
SUPABASE_SERVICE_ROLE_KEY=
ENCRYPTION_KEY=replace-with-32-plus-char-random-secret!!
SESSION_SECRET=replace-with-another-32-plus-char-secret!
CRON_SECRET=replace-with-16-plus-char-cron-secret

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://dailyresume.in/google-callback.html
REACT_APP_GOOGLE_REDIRECT_URI=https://dailyresume.in/google-callback.html

# Raspberry Pi worker
WORKER_ID=rpi-1
QUEUE_POLL_MS=5000
QUEUE_LEASE_SECONDS=900
